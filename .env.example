OPENAI_API_KEY=your_openai_api_key_here
DATABASE_URL=postgresql://postgres:password@localhost:5432/lawdb
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional overrides
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL=gpt-4.1-mini
PGVECTOR_TABLE=law_chunks
LAW_DOCUMENTS_TABLE=law_documents
RAG_TOP_K=5
MAX_CONTEXT_CHARS=12000
STREAM_EDIT_INTERVAL_SECONDS=1.0
STREAM_MIN_CHARS_PER_EDIT=80
LAW_DOCS_DIR=/home/youruser/law-docs
MINIO_PUBLIC_BASE_URL=http://YOUR_PUBLIC_IP:9000
MINIO_BUCKET=laws
MINIO_PREFIX=raw
